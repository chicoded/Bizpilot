// Prisma schema for BizPilot AI — multi-tenant SaaS for African SMEs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase direct connection for migrations
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum Industry {
  PHARMACY
  RETAIL
  SUPERMARKET
  COSMETICS
  FASHION
  MINI_MART
  ELECTRONICS
  RESTAURANT
  FAST_FOOD
  CAFE
  OTHER
}

enum KitchenOrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum RestaurantServiceType {
  WALK_IN
  DINE_IN
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS
  CREDIT
}

enum ExpenseCategory {
  RENT
  FUEL
  SALARY
  TRANSPORTATION
  ELECTRICITY
  SUPPLIES
  MAINTENANCE
  OTHER
}

enum SubscriptionPlan {
  STARTER
  BUSINESS
  AI_PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIAL
}

enum InternalAdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  FINANCE
  DEVELOPER
}

enum StockAdjustmentType {
  PURCHASE
  SALE
  DAMAGE
  THEFT
  EXPIRED
  RETURN
  MANUAL
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageStatus {
  RECEIVED
  REPLIED
  FAILED
}

model Business {
  id        String   @id @default(cuid())
  name      String
  industry  Industry @default(OTHER)
  /// Free-text industry when `industry` is OTHER (or a more specific label).
  industryLabel String?
  currency  String   @default("NGN")
  logo      String?
  address   String?
  phone     String?
  rolePermissions Json?
  /// When set, customer app access is blocked for this tenant.
  suspendedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  teamInvites    TeamInvite[]
  products       Product[]
  sales          Sale[]
  expenses       Expense[]
  customers      Customer[]
  suppliers      Supplier[]
  employees      Employee[]
  purchaseOrders PurchaseOrder[]
  subscription     Subscription?
  paymentTransactions PaymentTransaction[]
  auditLogs      AuditLog[]
  healthScores   BusinessHealthScore[]
  whatsappConfig WhatsAppConfig?
  whatsappMessages WhatsAppMessage[]
  aiPromptLogs   AiPromptLog[]
  receiptCounters ReceiptCounter[]
  restaurantSettings RestaurantSettings?
  mealCombos     MealCombo[]
  favoriteProducts FavoriteProduct[]
  kitchenOrders  KitchenOrder[]
  supportTickets SupportTicket[]

  @@map("businesses")
}

model User {
  id        String   @id
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  teamInvites     TeamInvite[] @relation("TeamInvitesSent")
  auditLogs       AuditLog[]
  internalAdmin   InternalAdmin?
  internalAudits  InternalAuditLog[]
  supportTickets  SupportTicket[]

  @@map("users")
}

/// Platform staff for /internal ops console (not tenant membership roles).
model InternalAdmin {
  id        String            @id @default(cuid())
  userId    String            @unique
  role      InternalAdminRole @default(SUPPORT)
  disabled  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@map("internal_admins")
}

model InternalAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@map("internal_audit_logs")
}

model Membership {
  id                String   @id @default(cuid())
  userId            String
  businessId        String
  role              Role     @default(STAFF)
  /// When set (array of section ids), replaces role-based page access for this member.
  sectionOverrides  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
  @@map("memberships")
}

model TeamInvite {
  id         String    @id @default(cuid())
  businessId String
  email      String
  role       Role      @default(STAFF)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inviter  User     @relation("TeamInvitesSent", fields: [invitedBy], references: [id])

  @@unique([businessId, email])
  @@index([businessId])
  @@map("team_invites")
}

enum ProductType {
  MENU_ITEM
  READY_MADE
  INGREDIENT
  PACKAGING
  SERVICE
}

model Product {
  id             String      @id @default(cuid())
  businessId     String
  name           String
  sku            String?
  barcode        String?
  category       String?
  supplierId     String?
  /// Hybrid inventory classification (restaurant + future verticals).
  productType    ProductType @default(READY_MADE)
  description    String?
  unit           String?
  prepTimeMinutes Int?
  isPopular      Boolean     @default(false)
  isChefSpecial  Boolean     @default(false)
  /// When false (typical MENU_ITEM), stock comes from recipe components.
  tracksStock    Boolean     @default(true)
  purchasePrice  Decimal     @default(0) @db.Decimal(12, 2)
  sellingPrice   Decimal     @default(0) @db.Decimal(12, 2)
  /// Units in one pack (e.g. 10 sachets). 1 = sold individually.
  unitsPerPack   Int         @default(1)
  quantity       Int         @default(0)
  reorderLevel   Int         @default(5)
  batchNumber    String?
  expiryDate     DateTime?
  imageUrl       String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  saleItems        SaleItem[]
  stockAdjustments StockAdjustment[]
  favoriteProducts FavoriteProduct[]
  mealComboItems   MealComboItem[]
  kitchenOrderItems KitchenOrderItem[]
  recipeLines      RecipeLine[]      @relation("RecipeParent")
  usedInRecipes    RecipeLine[]      @relation("RecipeComponent")

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([businessId, barcode])
  @@index([businessId, category])
  @@index([businessId, productType])
  @@map("products")
}

/// BOM: menu item consumes ingredients and/or packaging per sale unit.
model RecipeLine {
  id              String  @id @default(cuid())
  parentProductId String
  componentId     String
  quantity        Decimal @db.Decimal(12, 4)

  parent    Product @relation("RecipeParent", fields: [parentProductId], references: [id], onDelete: Cascade)
  component Product @relation("RecipeComponent", fields: [componentId], references: [id], onDelete: Restrict)

  @@unique([parentProductId, componentId])
  @@index([componentId])
  @@map("recipe_lines")
}

/// Per-business Rush POS settings (auto-enabled for restaurant industries).
model RestaurantSettings {
  id                   String   @id @default(cuid())
  businessId           String   @unique
  rushModeEnabled      Boolean  @default(true)
  voiceOrdersEnabled   Boolean  @default(false)
  aiSuggestionsEnabled Boolean  @default(true)
  comboMealsEnabled    Boolean  @default(true)
  kitchenDisplayEnabled Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("restaurant_settings")
}

model MealCombo {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  imageUrl    String?
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    MealComboItem[]

  @@index([businessId, isActive])
  @@map("meal_combos")
}

model MealComboItem {
  id        String @id @default(cuid())
  comboId   String
  productId String
  quantity  Int    @default(1)

  combo   MealCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comboId, productId])
  @@index([productId])
  @@map("meal_combo_items")
}

model FavoriteProduct {
  id         String @id @default(cuid())
  businessId String
  productId  String
  sortOrder  Int    @default(0)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([businessId, productId])
  @@index([businessId, sortOrder])
  @@map("favorite_products")
}

model KitchenOrder {
  id            String             @id @default(cuid())
  businessId    String
  saleId        String?
  orderNumber   String
  serviceType   RestaurantServiceType @default(WALK_IN)
  status        KitchenOrderStatus @default(PENDING)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  readyAt       DateTime?
  completedAt   DateTime?

  business Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    KitchenOrderItem[]

  @@unique([businessId, orderNumber])
  @@index([businessId, status, createdAt])
  @@map("kitchen_orders")
}

model KitchenOrderItem {
  id             String  @id @default(cuid())
  kitchenOrderId String
  productId      String?
  productName    String
  quantity       Int
  notes          String?

  kitchenOrder KitchenOrder @relation(fields: [kitchenOrderId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([kitchenOrderId])
  @@map("kitchen_order_items")
}

model StockAdjustment {
  id         String              @id @default(cuid())
  productId  String
  businessId String
  type       StockAdjustmentType
  quantity   Int
  reason     String?
  createdBy  String?
  createdAt  DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("stock_adjustments")
}

model Sale {
  id            String        @id @default(cuid())
  businessId    String
  customerId    String?
  /// Client-generated id for idempotent offline sync (unique per business)
  clientSaleId  String?
  /// Human-readable receipt number, e.g. RCP-20250703-0001 (unique per business)
  receiptNumber String
  paymentMethod PaymentMethod @default(CASH)
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  profit        Decimal       @default(0) @db.Decimal(12, 2)
  isCredit      Boolean       @default(false)
  dueDate       DateTime?
  notes         String?
  createdBy     String?
  createdAt     DateTime      @default(now())

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]

  @@unique([businessId, receiptNumber])
  @@unique([businessId, clientSaleId])
  @@index([businessId])
  @@index([businessId, createdAt])
  @@map("sales")
}

/// Atomic daily receipt sequence per business (RCP-YYYYMMDD-NNNN)
model ReceiptCounter {
  businessId String
  dateKey    String
  sequence   Int      @default(0)
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@id([businessId, dateKey])
  @@map("receipt_counters")
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  productId    String
  quantity     Int
  cost         Decimal @db.Decimal(12, 2)
  sellingPrice Decimal @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@map("sale_items")
}

model Expense {
  id          String          @id @default(cuid())
  businessId  String
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  date        DateTime        @default(now())
  createdBy   String?
  createdAt   DateTime        @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, date])
  @@map("expenses")
}

model Customer {
  id            String    @id @default(cuid())
  businessId    String
  name          String
  phone         String?
  email         String?
  debt          Decimal   @default(0) @db.Decimal(12, 2)
  lifetimeValue Decimal   @default(0) @db.Decimal(12, 2)
  lastPurchase  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([businessId])
  @@map("customers")
}

model Supplier {
  id         String   @id @default(cuid())
  businessId String
  name       String
  contact    String?
  email      String?
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([businessId])
  @@map("suppliers")
}

model PurchaseOrder {
  id         String   @id @default(cuid())
  businessId String
  supplierId String
  total      Decimal  @default(0) @db.Decimal(12, 2)
  status     String   @default("pending")
  notes      String?
  items      Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([businessId])
  @@map("purchase_orders")
}

model Employee {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  role        Role     @default(STAFF)
  phone       String?
  permissions Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("employees")
}

model Subscription {
  id                   String             @id @default(cuid())
  businessId           String             @unique
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(TRIAL)
  paystackCustomerCode String?
  paystackSubCode      String?
  lastPaymentReference String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@map("subscriptions")
}

model PaymentTransaction {
  id           String           @id @default(cuid())
  businessId   String
  subscriptionId String?
  reference    String           @unique
  plan         SubscriptionPlan
  amount       Decimal          @db.Decimal(12, 2)
  status       String           @default("pending")
  channel      String?
  paidAt       DateTime?
  metadata     Json?
  createdAt    DateTime         @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([businessId])
  @@map("payment_transactions")
}

model BusinessHealthScore {
  id              String   @id @default(cuid())
  businessId      String
  score           Int
  strengths       Json
  warnings        Json
  recommendations Json
  breakdown       Json?
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@map("business_health_scores")
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String
  entity     String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId, createdAt])
  @@map("audit_logs")
}

model WhatsAppConfig {
  id               String   @id @default(cuid())
  businessId       String   @unique
  isEnabled        Boolean  @default(false)
  whatsappNumber   String?
  twilioNumber     String?
  businessCode     String?  @unique
  greetingMessage  String?
  autoReplyEnabled Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([twilioNumber])
  @@map("whatsapp_configs")
}

model WhatsAppMessage {
  id            String                   @id @default(cuid())
  businessId    String
  direction     WhatsAppMessageDirection
  fromNumber    String
  toNumber      String
  body          String
  customerPhone String?
  aiResponse    String?
  status        WhatsAppMessageStatus    @default(RECEIVED)
  createdAt     DateTime                 @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([customerPhone])
  @@map("whatsapp_messages")
}

model AiPromptLog {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  createdAt  DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@map("ai_prompt_logs")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Customer bug reports / support requests (Settings → Help & support).
model SupportTicket {
  id         String              @id @default(cuid())
  businessId String?
  userId     String?
  email      String?
  summary    String
  details    String?
  pageUrl    String?
  status     SupportTicketStatus @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([businessId])
  @@index([createdAt])
  @@map("support_tickets")
}
