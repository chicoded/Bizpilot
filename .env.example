# =============================================================================
# BizPilot AI — Supabase + Clerk local development
# =============================================================================
# Copy this file:  cp .env.example .env.local
# Then fill in values from Supabase and Clerk dashboards.
# =============================================================================

# --- Supabase PostgreSQL (Settings → Database → Connection string) -----------
# Transaction pooler — use for DATABASE_URL (app runtime, Vercel, port 6543)
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for DIRECT_URL (migrations / prisma db push, port 5432)
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Supabase API (Settings → API) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy name (optional — publishable key works too)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Clerk (dashboard.clerk.com → API Keys) ----------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# --- App ---------------------------------------------------------------------
# Local: http://localhost:3000
# Vercel production: https://your-project.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional integrations ---------------------------------------------------
OPENAI_API_KEY=
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_BUSINESS=
PAYSTACK_PLAN_AI_PRO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
