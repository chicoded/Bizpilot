# =============================================================================
# BizPilot AI — Supabase + Clerk local development
# =============================================================================
# Copy this file:  cp .env.example .env.local
# Then fill in values from Supabase and Clerk dashboards.
# =============================================================================

# --- Supabase PostgreSQL (Settings → Database → Connection string) -----------
# Transaction pooler — use for DATABASE_URL (app runtime, Vercel, port 6543)
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for DIRECT_URL (migrations / prisma db push, port 5432)
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Supabase API (Settings → API) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy name (optional — publishable key works too)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Required for product image uploads (Supabase → API → service_role key)

# --- Clerk (dashboard.clerk.com → API Keys) ----------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# --- App ---------------------------------------------------------------------
# Local: http://localhost:3000
# Production: optional — Vercel auto-detects your .vercel.app URL if unset or still localhost
# Use your shortest domain when you have one, e.g. https://bizpilot.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Internal Ops Console (/internal) — staff only, never link from customer UI ---
# Comma-separated emails bootstrap as SUPER_ADMIN into internal_admins
# Staff login UI: /internal/sign-in (Clerk). Customer login stays /sign-in.
INTERNAL_ADMIN_EMAILS=you@company.com

# --- Customer support (bug reports) ------------------------------------------
# Shown in Settings → Help & support and on /support
# WhatsApp: Nigerian format ok (080...) or +234...
NEXT_PUBLIC_SUPPORT_WHATSAPP=08012345678
NEXT_PUBLIC_SUPPORT_EMAIL=you@email.com

# --- Optional integrations ---------------------------------------------------
# Free AI (recommended): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Paid fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Flutterwave billing (active)
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
# Dashboard → Settings → Webhooks → Secret hash
FLUTTERWAVE_SECRET_HASH=
# Optional recurring payment plan IDs from Flutterwave
FLUTTERWAVE_PLAN_STARTER=
FLUTTERWAVE_PLAN_BUSINESS=
FLUTTERWAVE_PLAN_AI_PRO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Gmail + Google Drive backup (optional — automatic send/upload) ---
# Google Cloud Console → enable Gmail API + Google Drive API
# OAuth 2.0 Client ID (Web application)
# Scopes used: gmail.send, drive.file, userinfo.email
# Authorized redirect URI: https://your-domain.com/settings/backup
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
