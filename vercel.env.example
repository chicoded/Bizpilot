# Paste these into Vercel → Project → Settings → Environment Variables
# Enable for: Production, Preview, and Development (where noted)

# === REQUIRED (Vercel Production) ===
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Required for prisma migrate deploy on Vercel builds (session pooler, port 5432)
DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_APP_URL=https://www.ritualgames.com.ng

# Use LIVE Clerk keys in Production AND Preview on Vercel (pk_live_ / sk_live_).
# Test keys (pk_test_) show "development keys" warnings and break production auth.

# Clerk paths (same for all environments)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Vercel Preview: add DATABASE_URL, DIRECT_URL, and Clerk keys under Preview env.
# If Preview Deployment Protection (SSO) is on, disable it or test on production URL instead.

# Supabase API (if using client-side Supabase features)
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Product image uploads (Supabase → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === OPTIONAL ===
OPENAI_API_KEY=
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
